# ============================================================
# ENV TEMPLATE — Copy to .env.local and fill in your values.
# ============================================================

# --- Sanity CMS (optional) ---
# Create a project at https://sanity.io
# If not set, the site renders without dynamic content.
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_API_READ_TOKEN=   # optional, for private datasets
SANITY_API_WRITE_TOKEN= # optional, for write operations

# --- Resend Email (optional) ---
# Get a key at https://resend.com
# If not set, emails are silently skipped.
RESEND_API_KEY=re_your_key_here

# --- PayPal (optional, for shop/checkout) ---
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# --- Stripe (optional, for shop/checkout) ---
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000